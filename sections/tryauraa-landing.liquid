{% comment %}
  Paste these Google Fonts <link> tags into layout/theme.liquid inside <head>:

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,400..600&family=Hanken+Grotesk:wght@300..700&display=swap" rel="stylesheet">
{% endcomment %}

<div
  class="tryauraa-landing"
  id="tryauraa-{{ section.id }}"
  data-tryauraa-section="{{ section.id }}"
  data-tryon-dress-1="{% if section.settings.tryon_dress_1 != blank %}{{ section.settings.tryon_dress_1 | image_url: width: 800 }}{% endif %}"
  data-tryon-dress-2="{% if section.settings.tryon_dress_2 != blank %}{{ section.settings.tryon_dress_2 | image_url: width: 800 }}{% endif %}"
  data-tryon-tee-white="{% if section.settings.tryon_tee_white != blank %}{{ section.settings.tryon_tee_white | image_url: width: 800 }}{% endif %}"
  data-tryon-tee-black="{% if section.settings.tryon_tee_black != blank %}{{ section.settings.tryon_tee_black | image_url: width: 800 }}{% endif %}"
  data-tryon-tee-sand="{% if section.settings.tryon_tee_sand != blank %}{{ section.settings.tryon_tee_sand | image_url: width: 800 }}{% endif %}"
>
  <nav class="tryauraa-nav">
    <div class="tryauraa-wrap tryauraa-nav-in">
      <a class="tryauraa-wm" href="#tryauraa-hero-{{ section.id }}"><span class="tryauraa-wm-a">try</span><span class="tryauraa-wm-b">auraa</span></a>
      <div class="tryauraa-nav-links">
        <a href="#tryauraa-how-{{ section.id }}">How it works</a>
        <a href="#tryauraa-features-{{ section.id }}">Features</a>
        <a href="#tryauraa-pricing-{{ section.id }}">Pricing</a>
        <a href="#tryauraa-faq-{{ section.id }}">FAQ</a>
      </div>
      <div class="tryauraa-nav-cta">
        <a href="{% if section.settings.secondary_cta_url != blank %}{{ section.settings.secondary_cta_url }}{% else %}#tryauraa-demo-{{ section.id }}{% endif %}" class="tryauraa-btn tryauraa-btn-ghost">{{ section.settings.secondary_cta_label }}</a>
        <a href="{{ section.settings.install_url }}" class="tryauraa-btn tryauraa-btn-gold">Add to Shopify</a>
      </div>
    </div>
  </nav>

  <header class="tryauraa-hero" id="tryauraa-hero-{{ section.id }}">
    <div class="tryauraa-wrap tryauraa-hero-grid">
      <div>
        <div class="tryauraa-badge"><span class="tryauraa-dot"></span> {{ section.settings.hero_badge }}</div>
        <h1 class="tryauraa-hero-title">{{ section.settings.hero_heading }}</h1>
        <p class="tryauraa-sub">{{ section.settings.hero_subline }}</p>
        <div class="tryauraa-hero-cta">
          <a href="{% if section.settings.primary_cta_url != blank %}{{ section.settings.primary_cta_url }}{% else %}{{ section.settings.install_url }}{% endif %}" class="tryauraa-btn tryauraa-btn-gold">{{ section.settings.primary_cta_label }}</a>
          <a href="{% if section.settings.secondary_cta_url != blank %}{{ section.settings.secondary_cta_url }}{% else %}#tryauraa-demo-{{ section.id }}{% endif %}" class="tryauraa-btn tryauraa-btn-ghost">{{ section.settings.secondary_cta_label }}</a>
        </div>
        <div class="tryauraa-hero-mini">
          <span>✓ Live in minutes</span>
          <span>✓ Works with any theme</span>
          <span>✓ 7-day free trial</span>
        </div>
      </div>

      <div class="tryauraa-demo" id="tryauraa-demo-{{ section.id }}">
        <div class="tryauraa-demo-head">
          <span class="tryauraa-demo-tag">Live try-on</span>
          <span class="tryauraa-demo-status"><span class="tryauraa-live"></span> Tap an item</span>
        </div>
        <div class="tryauraa-stage-wrap" id="tryauraa-stage-{{ section.id }}">
          <div class="tryauraa-gen-label"><span class="tryauraa-spin"></span> Generating your look</div>
          <div class="tryauraa-shimmer"></div>
          <div class="tryauraa-stage-photo" id="tryauraa-photo-wrap-{{ section.id }}" hidden>
            <img
              id="tryauraa-photo-{{ section.id }}"
              class="tryauraa-stage-photo-img"
              src=""
              alt="Virtual try-on preview"
              width="800"
              height="800"
              loading="lazy"
            >
          </div>
          <svg class="tryauraa-stage-svg" id="tryauraa-stage-svg-{{ section.id }}" viewBox="0 0 280 470" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <ellipse cx="140" cy="452" rx="86" ry="15" fill="#2E2419" opacity="0.08"/>
            <rect x="135" y="300" width="10" height="150" rx="4" fill="#B59A5A"/>
            <ellipse cx="140" cy="448" rx="58" ry="11" fill="#C2A14E"/>
            <ellipse cx="140" cy="445" rx="58" ry="11" fill="#D8BE7E"/>

            <g id="tryauraa-form-fem-{{ section.id }}">
              <path d="M126 64 L154 64 C160 76 158 90 165 104 C184 116 197 140 195 164 C193 200 173 222 171 244 C170 274 191 296 189 318 C188 344 175 366 156 376 L124 376 C105 366 92 344 91 318 C89 296 110 274 109 244 C107 222 87 200 85 164 C83 140 96 116 115 104 C122 90 120 76 126 64 Z" fill="#E4D2B4" stroke="#CBB68F" stroke-width="1.5"/>
              <ellipse cx="140" cy="62" rx="16" ry="6" fill="#D8C3A0"/>
            </g>

            <g id="tryauraa-form-male-{{ section.id }}" style="display:none">
              <path d="M122 66 L158 66 C164 78 162 92 174 100 C198 106 214 120 212 142 C210 200 204 280 198 348 C197 362 188 372 176 374 L104 374 C92 372 83 362 82 348 C76 280 70 200 68 142 C66 120 82 106 106 100 C118 92 116 78 122 66 Z" fill="#E0CBA8" stroke="#C7B086" stroke-width="1.5"/>
              <ellipse cx="140" cy="64" rx="17" ry="6" fill="#D3BD96"/>
            </g>

            <g class="tryauraa-garment tryauraa-on" id="tryauraa-g-dress-{{ section.id }}">
              <path d="M118 96 C112 130 92 168 96 210 C82 280 74 360 90 416 C120 426 160 426 190 416 C206 360 198 280 184 210 C188 168 168 130 162 96 C154 92 148 102 140 102 C132 102 126 92 118 96 Z" fill="#C2A14E"/>
              <path d="M122 98 L130 90 M158 98 L150 90" stroke="#C2A14E" stroke-width="6" stroke-linecap="round"/>
              <path d="M118 96 C112 130 92 168 96 210 C160 224 188 168 162 96 C154 92 148 102 140 102 C132 102 126 92 118 96 Z" fill="#CBAE5E" opacity="0.5"/>
            </g>

            <g class="tryauraa-garment" id="tryauraa-g-wrap-{{ section.id }}">
              <path d="M116 100 C110 130 94 165 98 205 C86 270 80 350 92 404 C120 414 160 414 188 404 C200 350 194 270 182 205 C186 165 170 130 164 100 C156 96 150 134 140 152 C130 134 124 96 116 100 Z" fill="#B58E40"/>
              <path d="M122 108 L150 175 M158 108 L130 175" stroke="#9C7732" stroke-width="3" fill="none"/>
              <rect x="94" y="206" width="92" height="12" rx="3" fill="#8A6526"/>
            </g>

            <g class="tryauraa-garment" id="tryauraa-g-tee-{{ section.id }}">
              <path id="tryauraa-tee-body-{{ section.id }}" d="M102 98 C82 102 62 114 54 140 C60 150 66 162 72 170 C82 162 90 152 100 150 C92 210 90 270 94 312 C122 320 160 320 188 312 C192 270 190 210 182 150 C192 152 200 162 210 170 C216 162 222 150 228 140 C220 114 200 102 180 98 C168 102 160 112 140 112 C120 112 112 102 102 98 Z" fill="#FFFFFF"/>
              <path d="M118 102 C128 118 152 118 162 102" stroke="rgba(0,0,0,.16)" stroke-width="3" fill="none"/>
            </g>
          </svg>
        </div>

        <div class="tryauraa-cat-label">Womenswear</div>
        <div class="tryauraa-rack">
          <button type="button" class="tryauraa-item tryauraa-active" data-type="dress" data-garment="tryauraa-g-dress-{{ section.id }}" data-tryon-key="dress_1">
            <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><path d="M14 6l6-3 6 3-3 9 4 22H13l4-22z" fill="#C2A14E"/></svg>
            <span>Slip Dress</span>
          </button>
          <button type="button" class="tryauraa-item" data-type="dress" data-garment="tryauraa-g-wrap-{{ section.id }}" data-tryon-key="dress_2">
            <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><path d="M14 6l6 8 6-8 3 8-3 21H14l-3-21z" fill="#B58E40"/></svg>
            <span>Wrap Dress</span>
          </button>
        </div>

        <div class="tryauraa-cat-label">Menswear t-shirts</div>
        <div class="tryauraa-rack tryauraa-three">
          <button type="button" class="tryauraa-item" data-type="tee" data-color="#FFFFFF" data-tryon-key="tee_white">
            <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><path d="M14 7l-8 5 3 5 5-3v18h12V14l5 3 3-5-8-5c-2 3-4 4-6 4s-4-1-6-4z" fill="#FFFFFF" stroke="#D8C8A6"/></svg>
            <span>White Tee</span>
          </button>
          <button type="button" class="tryauraa-item" data-type="tee" data-color="#2E2419" data-tryon-key="tee_black">
            <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><path d="M14 7l-8 5 3 5 5-3v18h12V14l5 3 3-5-8-5c-2 3-4 4-6 4s-4-1-6-4z" fill="#2E2419"/></svg>
            <span>Black Tee</span>
          </button>
          <button type="button" class="tryauraa-item" data-type="tee" data-color="#A6906F" data-tryon-key="tee_sand">
            <svg viewBox="0 0 40 40" fill="none" aria-hidden="true"><path d="M14 7l-8 5 3 5 5-3v18h12V14l5 3 3-5-8-5c-2 3-4 4-6 4s-4-1-6-4z" fill="#A6906F"/></svg>
            <span>Sand Tee</span>
          </button>
        </div>
        <p class="tryauraa-demo-foot">Same experience your shoppers get on every product page, for men and women.</p>
      </div>
    </div>
  </header>

  <div class="tryauraa-logos">
    <div class="tryauraa-wrap">
      <p>Made for premium Shopify fashion stores</p>
      <div class="tryauraa-logo-row">
        {% for block in section.blocks %}
          {% if block.type == 'brand' %}
            <span {{ block.shopify_attributes }}>{{ block.settings.name }}</span>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="tryauraa-stats tryauraa-reveal">
    <div class="tryauraa-wrap tryauraa-stats-grid">
      <div class="tryauraa-stat">
        <div class="tryauraa-n">{{ section.settings.stat_1_number }}</div>
        <div class="tryauraa-l">{{ section.settings.stat_1_label }}</div>
      </div>
      <div class="tryauraa-stat">
        <div class="tryauraa-n">{{ section.settings.stat_2_number }}</div>
        <div class="tryauraa-l">{{ section.settings.stat_2_label }}</div>
      </div>
      <div class="tryauraa-stat">
        <div class="tryauraa-n">{{ section.settings.stat_3_number }}</div>
        <div class="tryauraa-l">{{ section.settings.stat_3_label }}</div>
      </div>
    </div>
  </div>

  <section class="tryauraa-section" id="tryauraa-features-{{ section.id }}">
    <div class="tryauraa-wrap">
      <div class="tryauraa-center tryauraa-reveal">
        <div class="tryauraa-s-label">Why Tryauraa</div>
        <h2 class="tryauraa-s-title">Everything a fashion store needs<br>to sell with confidence</h2>
      </div>

      <div class="tryauraa-feat tryauraa-reveal">
        <div>
          <div class="tryauraa-kick">{{ section.settings.feature_1_kicker }}</div>
          <h3>{{ section.settings.feature_1_title }}</h3>
          <p>{{ section.settings.feature_1_body }}</p>
        </div>
        <div class="tryauraa-feat-visual tryauraa-fv-1">
          <svg width="150" height="180" viewBox="0 0 150 180" aria-hidden="true"><ellipse cx="75" cy="168" rx="46" ry="8" fill="#2E2419" opacity=".08"/><path d="M55 30c-4 20-14 40-12 64-6 40-4 60 4 78 18 6 38 6 56 0 8-18 10-38 4-78 2-24-8-44-12-64-6-4-12 6-20 6s-14-10-20-6z" fill="#C2A14E"/><circle cx="75" cy="20" r="14" fill="#E4D2B4"/></svg>
        </div>
      </div>

      <div class="tryauraa-feat tryauraa-reveal">
        <div>
          <div class="tryauraa-kick">{{ section.settings.feature_2_kicker }}</div>
          <h3>{{ section.settings.feature_2_title }}</h3>
          <p>{{ section.settings.feature_2_body }}</p>
        </div>
        <div class="tryauraa-feat-visual tryauraa-fv-2">
          <svg width="180" height="150" viewBox="0 0 180 150" aria-hidden="true"><rect x="20" y="24" width="140" height="100" rx="10" fill="#FAF4E9" opacity=".95"/><rect x="20" y="24" width="140" height="22" rx="10" fill="#C2A14E"/><circle cx="33" cy="35" r="3" fill="#FAF4E9"/><circle cx="44" cy="35" r="3" fill="#FAF4E9"/><rect x="34" y="60" width="50" height="48" rx="6" fill="#E7D9C0"/><rect x="96" y="60" width="48" height="9" rx="4" fill="#A6906F"/><rect x="96" y="78" width="40" height="9" rx="4" fill="#D8C8A6"/><rect x="96" y="96" width="44" height="12" rx="6" fill="#C2A14E"/></svg>
        </div>
      </div>

      <div class="tryauraa-feat tryauraa-reveal">
        <div>
          <div class="tryauraa-kick">{{ section.settings.feature_3_kicker }}</div>
          <h3>{{ section.settings.feature_3_title }}</h3>
          <p>{{ section.settings.feature_3_body }}</p>
        </div>
        <div class="tryauraa-feat-visual tryauraa-fv-3">
          <svg width="190" height="150" viewBox="0 0 190 150" aria-hidden="true"><polyline points="20,120 55,95 90,105 125,60 165,35" fill="none" stroke="#C2A14E" stroke-width="5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="165" cy="35" r="7" fill="#A07D32"/><line x1="20" y1="130" x2="175" y2="130" stroke="#A6906F" stroke-width="2"/><rect x="36" y="115" width="14" height="15" fill="#E4D2B4"/><rect x="76" y="108" width="14" height="22" fill="#D8C8A6"/><rect x="116" y="92" width="14" height="38" fill="#C9B488"/></svg>
        </div>
      </div>

      <div class="tryauraa-feat tryauraa-reveal">
        <div>
          <div class="tryauraa-kick">{{ section.settings.feature_4_kicker }}</div>
          <h3>{{ section.settings.feature_4_title }}</h3>
          <p>{{ section.settings.feature_4_body }}</p>
        </div>
        <div class="tryauraa-feat-visual tryauraa-fv-4">
          <svg width="170" height="150" viewBox="0 0 170 150" aria-hidden="true"><rect x="30" y="20" width="48" height="100" rx="8" fill="#FAF4E9"/><rect x="86" y="36" width="48" height="84" rx="8" fill="#FAF4E9" opacity=".85"/><circle cx="54" cy="48" r="13" fill="#E4D2B4"/><rect x="40" y="70" width="28" height="40" rx="6" fill="#2E2419"/><path d="M150 30l4 9 9 1-6 7 2 9-9-5-9 5 2-9-6-7 9-1z" fill="#FAF4E9"/></svg>
        </div>
      </div>
    </div>
  </section>

  <section class="tryauraa-how tryauraa-section" id="tryauraa-how-{{ section.id }}">
    <div class="tryauraa-wrap">
      <div class="tryauraa-center tryauraa-reveal">
        <div class="tryauraa-s-label">How it works</div>
        <h2 class="tryauraa-s-title">From browsing to buying in three steps</h2>
      </div>
      <div class="tryauraa-steps">
        <div class="tryauraa-step tryauraa-reveal"><div class="tryauraa-num">01</div><h4>Shopper picks a photo</h4><p>They upload a quick photo or choose a model on the product page. One tap, no account needed.</p></div>
        <div class="tryauraa-step tryauraa-reveal"><div class="tryauraa-num">02</div><h4>Tryauraa generates the look</h4><p>Our AI places your product on them in seconds, with natural fit and matched lighting.</p></div>
        <div class="tryauraa-step tryauraa-reveal"><div class="tryauraa-num">03</div><h4>They buy with confidence</h4><p>Seeing the fit removes the guesswork, so more carts convert and fewer items come back.</p></div>
      </div>
    </div>
  </section>

  <section class="tryauraa-section tryauraa-reveal">
    <div class="tryauraa-wrap tryauraa-quote">
      <blockquote>{{ section.settings.testimonial_quote }}</blockquote>
      <div class="tryauraa-who">{{ section.settings.testimonial_author }}<span>{{ section.settings.testimonial_author_role }}</span></div>
    </div>
  </section>

  <section class="tryauraa-section" id="tryauraa-pricing-{{ section.id }}">
    <div class="tryauraa-wrap">
      <div class="tryauraa-center tryauraa-reveal">
        <div class="tryauraa-s-label">Pricing</div>
        <h2 class="tryauraa-s-title">Plans that scale with your store</h2>
        <p class="tryauraa-s-intro">Every plan starts with a 7-day free trial. Cancel anytime from your Shopify admin.</p>
      </div>
      <div class="tryauraa-price-grid">
        <div class="tryauraa-plan tryauraa-reveal">
          <h4>{{ section.settings.tier_1_name }}</h4>
          <div class="tryauraa-pr">{{ section.settings.tier_1_price }}<small>/mo</small></div>
          <div class="tryauraa-trial">7-day free trial</div>
          <ul>
            {% assign tier_1_lines = section.settings.tier_1_features | newline_to_br | split: '<br />' %}
            {% for line in tier_1_lines %}
              {% if line != blank %}<li>{{ line | strip }}</li>{% endif %}
            {% endfor %}
          </ul>
          <a href="{{ section.settings.tier_1_button_url }}" class="tryauraa-btn tryauraa-btn-ghost">{{ section.settings.tier_1_button_label }}</a>
        </div>

        <div class="tryauraa-plan tryauraa-feature tryauraa-reveal">
          {% if section.settings.tier_2_featured %}<span class="tryauraa-tag">Most popular</span>{% endif %}
          <h4>{{ section.settings.tier_2_name }}</h4>
          <div class="tryauraa-pr">{{ section.settings.tier_2_price }}<small>/mo</small></div>
          <div class="tryauraa-trial">7-day free trial</div>
          <ul>
            {% assign tier_2_lines = section.settings.tier_2_features | newline_to_br | split: '<br />' %}
            {% for line in tier_2_lines %}
              {% if line != blank %}<li>{{ line | strip }}</li>{% endif %}
            {% endfor %}
          </ul>
          <a href="{{ section.settings.tier_2_button_url }}" class="tryauraa-btn tryauraa-btn-gold">{{ section.settings.tier_2_button_label }}</a>
        </div>

        <div class="tryauraa-plan tryauraa-reveal">
          <h4>{{ section.settings.tier_3_name }}</h4>
          <div class="tryauraa-pr">{{ section.settings.tier_3_price }}<small>/mo</small></div>
          <div class="tryauraa-trial">7-day free trial</div>
          <ul>
            {% assign tier_3_lines = section.settings.tier_3_features | newline_to_br | split: '<br />' %}
            {% for line in tier_3_lines %}
              {% if line != blank %}<li>{{ line | strip }}</li>{% endif %}
            {% endfor %}
          </ul>
          <a href="{{ section.settings.tier_3_button_url }}" class="tryauraa-btn tryauraa-btn-ghost">{{ section.settings.tier_3_button_label }}</a>
        </div>
      </div>
    </div>
  </section>

  <section class="tryauraa-section" id="tryauraa-faq-{{ section.id }}">
    <div class="tryauraa-wrap">
      <div class="tryauraa-center tryauraa-reveal">
        <div class="tryauraa-s-label">FAQ</div>
        <h2 class="tryauraa-s-title">Good questions, answered</h2>
      </div>
      <div class="tryauraa-faq tryauraa-reveal">
        <div class="tryauraa-q"><button type="button">How does installation work?<span class="tryauraa-ic">+</span></button><div class="tryauraa-ans"><p>Install Tryauraa from the Shopify App Store, choose the products you want to enable, and publish. The try-on button appears on those product pages right away.</p></div></div>
        <div class="tryauraa-q"><button type="button">Do I need a developer or code?<span class="tryauraa-ic">+</span></button><div class="tryauraa-ans"><p>No. Tryauraa works with any Shopify theme and adds itself to your product pages with no theme edits or code changes.</p></div></div>
        <div class="tryauraa-q"><button type="button">Does it work for menswear and womenswear?<span class="tryauraa-ic">+</span></button><div class="tryauraa-ans"><p>Yes. Tryauraa handles dresses, t-shirts, outerwear, and more, for both men's and women's collections.</p></div></div>
        <div class="tryauraa-q"><button type="button">Will it match my store's look?<span class="tryauraa-ic">+</span></button><div class="tryauraa-ans"><p>Yes. The try-on experience inherits your fonts and colors, and you can customize the button, copy, and layout to fit your brand.</p></div></div>
        <div class="tryauraa-q"><button type="button">Is shopper data kept private?<span class="tryauraa-ic">+</span></button><div class="tryauraa-ans"><p>Yes. Uploaded photos are used only to generate the try-on and are handled in line with our privacy policy. Shoppers stay in control of their images.</p></div></div>
      </div>
    </div>
  </section>

  <div class="tryauraa-cta-band tryauraa-reveal" id="tryauraa-install-{{ section.id }}">
    <h2>Give every shopper a <em>fitting room</em>.</h2>
    <p>Add Tryauraa to your Shopify store and let your products sell themselves on.</p>
    <a href="{{ section.settings.install_url }}" class="tryauraa-btn tryauraa-btn-gold">Add to Shopify</a>
  </div>

  <footer class="tryauraa-footer">
    <div class="tryauraa-wrap">
      <div class="tryauraa-foot-grid">
        <div>
          <div class="tryauraa-foot-wm">try<span class="tryauraa-wm-b">auraa</span></div>
          <div class="tryauraa-foot-tag">{{ section.settings.footer_tagline }}</div>
        </div>
        <div class="tryauraa-foot-links">
          <div class="tryauraa-foot-col">
            <h5>Product</h5>
            {% for block in section.blocks %}
              {% if block.type == 'link' and block.settings.column == 'product' %}
                <a href="{{ block.settings.url }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
              {% endif %}
            {% endfor %}
          </div>
          <div class="tryauraa-foot-col">
            <h5>Company</h5>
            {% for block in section.blocks %}
              {% if block.type == 'link' and block.settings.column == 'company' %}
                <a href="{{ block.settings.url }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
              {% endif %}
            {% endfor %}
          </div>
          <div class="tryauraa-foot-col">
            <h5>Legal</h5>
            {% for block in section.blocks %}
              {% if block.type == 'link' and block.settings.column == 'legal' %}
                <a href="{{ block.settings.url }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </div>
      <div class="tryauraa-foot-bot">
        <span>© {{ 'now' | date: '%Y' }} Tryauraa. All rights reserved.</span>
        <span>tryauraa.com</span>
      </div>
    </div>
  </footer>
</div>

{% stylesheet %}
.tryauraa-landing{
  scroll-behavior:smooth;
  --gold:#C2A14E; --bronze:#A07D32; --taupe:#A6906F;
