{% javascript %}
(function () {
  const sectionId = '{{ section.id }}';
  const root = document.getElementById('tryauraa-' + sectionId);
  if (!root) return;

  const stage = document.getElementById('tryauraa-stage-' + sectionId);
  const formFem = document.getElementById('tryauraa-form-fem-' + sectionId);
  const formMale = document.getElementById('tryauraa-form-male-' + sectionId);
  const tee = document.getElementById('tryauraa-g-tee-' + sectionId);
  const teeBody = document.getElementById('tryauraa-tee-body-' + sectionId);
  const stageSvg = document.getElementById('tryauraa-stage-svg-' + sectionId);
  const photoWrap = document.getElementById('tryauraa-photo-wrap-' + sectionId);
  const photoImg = document.getElementById('tryauraa-photo-' + sectionId);
  const rack = root.querySelectorAll('.tryauraa-item');
  let timer = null;

  const tryonImages = {
    dress_1: root.dataset.tryonDress1 || '',
    dress_2: root.dataset.tryonDress2 || '',
    tee_white: root.dataset.tryonTeeWhite || '',
    tee_black: root.dataset.tryonTeeBlack || '',
    tee_sand: root.dataset.tryonTeeSand || ''
  };

  function clearGarments() {
    root.querySelectorAll('.tryauraa-garment').forEach(function (g) {
      g.classList.remove('tryauraa-on');
    });
  }

  function showSvgMode() {
    stage.classList.remove('tryauraa-photo-mode');
    if (photoWrap) photoWrap.hidden = true;
    if (stageSvg) stageSvg.hidden = false;
  }

  function showPhotoMode(url) {
    if (!photoWrap || !photoImg || !url) return false;
    photoImg.src = url;
    photoImg.alt = 'Virtual try-on preview';
    photoWrap.hidden = false;
    stage.classList.add('tryauraa-photo-mode');
    return true;
  }

  rack.forEach(function (btn) {
    btn.addEventListener('click', function () {
      rack.forEach(function (i) { i.classList.remove('tryauraa-active'); });
      btn.classList.add('tryauraa-active');
      clearTimeout(timer);
      stage.classList.add('tryauraa-gen');

      timer = setTimeout(function () {
        stage.classList.remove('tryauraa-gen');
        const tryonKey = btn.dataset.tryonKey;
        const imageUrl = tryonImages[tryonKey];

        if (imageUrl && showPhotoMode(imageUrl)) {
          return;
        }

        showSvgMode();

        if (btn.dataset.type === 'tee') {
          formFem.style.display = 'none';
          formMale.style.display = '';
          teeBody.setAttribute('fill', btn.dataset.color);
          tee.classList.add('tryauraa-on');
        } else {
          formMale.style.display = 'none';
          formFem.style.display = '';
          var garment = document.getElementById(btn.dataset.garment);
          if (garment) garment.classList.add('tryauraa-on');
        }
      }, 850);
    });
  });

  root.querySelectorAll('.tryauraa-q button').forEach(function (b) {
    b.addEventListener('click', function () {
      b.parentElement.classList.toggle('tryauraa-open');
    });
  });

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) {
        e.target.classList.add('tryauraa-in');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  root.querySelectorAll('.tryauraa-reveal').forEach(function (el) {
    io.observe(el);
  });
})();
{% endjavascript %}

