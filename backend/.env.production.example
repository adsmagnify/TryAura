# Copy values into Render → tryaura-api → Environment
NODE_ENV=production
PORT=3001
USE_SUPABASE=true
USE_R2_STORAGE=false
ENABLE_JOB_WORKER=true

BACKEND_URL=https://tryaura-api.onrender.com
FRONTEND_URL=https://tryaura-app.onrender.com

DATABASE_URL=postgresql://...pooler:6543/postgres?pgbouncer=true
# DIRECT_URL is auto-derived from DATABASE_URL (6543 → 5432) — no need to set on Render
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_themes,write_themes,read_customers
WEBHOOK_SECRET=
API_SECRET=
PLATFORM_ADMIN_SECRET=thisisforadminsonly
NANOBANANA_API_KEY=
