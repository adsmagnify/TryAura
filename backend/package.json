{
  "name": "tryon-backend",
  "version": "1.0.0",
  "description": "AI Virtual Try-On Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "prestart": "node -e \"require('dotenv').config();require('./src/lib/dbUrl');require('./src/lib/ensureSchema').ensureSchema().catch(e=>{console.error(e);process.exit(1)})\"",
    "dev": "nodemon src/server.js",
    "dev:tunnel": "node scripts/dev-with-tunnel.js",
    "test": "jest --passWithNoTests",
    "db:migrate": "node scripts/run-migration.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@shopify/shopify-api": "^13.0.0",
    "axios": "^1.6.0",
    "better-sqlite3": "^11.6.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^4.0.0",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^3.3.2",
    "sharp": "^0.33.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2"
  }
}
