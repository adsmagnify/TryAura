# =============================================================================
# TryAura Backend — Environment Variables
# Copy to .env for local dev. Set in Render dashboard for production.
# =============================================================================

NODE_ENV=development
PORT=3001

# Public URLs (no trailing slash)
BACKEND_URL=https://your-app.onrender.com
FRONTEND_URL=https://your-app.onrender.com

# Shopify App (Partners Dashboard)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products,read_themes,write_themes,read_customers

# Webhook HMAC — use SHOPIFY_API_SECRET in production (same as app secret)
WEBHOOK_SECRET=

# Admin API key (embedded app → backend via x-tryon-api-key)
API_SECRET=
API_KEY_HEADER=x-tryon-api-key

# AI
NANOBANANA_API_KEY=
AI_PROVIDER=nanobanana

# Feature flags (incremental migration)
USE_SUPABASE=false
USE_R2_STORAGE=false
USE_ASYNC_JOBS=false
ENABLE_JOB_WORKER=true

# Supabase (Postgres) — get from Project Settings → Database
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection for migrations only:
DIRECT_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=tryaura-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10
STOREFRONT_RATE_LIMIT_MAX=5

# Upload limits
MAX_FILE_SIZE_MB=10
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp
IMAGE_TTL_SECONDS=3600

# Job worker
JOB_WORKER_INTERVAL_MS=2000
JOB_WORKER_BATCH_SIZE=3
JOB_MAX_ATTEMPTS=3
JOB_RETRY_BASE_MS=5000

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Error tracking (optional)
SENTRY_DSN=

# Billing (Phase 4)
# SHOPIFY_BILLING_TEST=true
