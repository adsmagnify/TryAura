{% comment %}
  TryAura Virtual Try-On — Theme settings → App embeds → Virtual Try-On → Save
{% endcomment %}
{% liquid
  assign tryon_api = block.settings.api_url
  if tryon_api == blank
    assign tryon_api = shop.metafields.app.api_url.value | default: shop.metafields.tryaura.api_url.value
  endif
  if tryon_api == blank
    assign tryon_api = 'https://tryaura-api.onrender.com'
  endif
%}
{% if product %}
  {% if product.featured_image %}
    {% assign garment_img = product.featured_image | image_url: width: 1200 %}
    {% unless garment_img contains 'https://' or garment_img contains 'http://' %}
      {% assign garment_img = garment_img | prepend: 'https:' %}
    {% endunless %}
  {% endif %}
  <script>
    window.TRYON_BACKEND_URL = {{ tryon_api | json }};
    window.TryOnConfig = {
      apiUrl: window.TRYON_BACKEND_URL,
      productId: {{ product.id | json }},
      garmentImageUrl: {% if product.featured_image %}{{ garment_img | json }}{% else %}null{% endif %},
      shop: {{ shop.permanent_domain | json }},
    };
  </script>
{% endif %}

{% schema %}
{
  "name": "Virtual Try-On",
  "target": "body",
  "enabled_on": {
    "templates": ["product"]
  },
  "javascript": "tryon-widget.js",
  "settings": [
    {
      "type": "text",
      "id": "api_url",
      "label": "Backend API URL",
      "default": "https://tryaura-api.onrender.com",
      "info": "Usually leave as default. TryAura sets this automatically when permissions allow."
    }
  ]
}
{% endschema %}
